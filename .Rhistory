rates_split_week <- compute_rates_weekly_with_ideal(split_cum, id_cols = c("label")) %>%
dplyr::rename(series = label) %>%
dplyr::mutate(
current_rate_per_week = round(current_rate_per_week, round_digits),
required_rate_per_week_from_2026_02_01 = round(required_rate_per_week_from_2026_02_01, round_digits),
delta_rate_per_week = round(delta_rate_per_week, round_digits)
)
rate_summary <- rates_vanilla_week %>%
dplyr::summarise(
mean_current_rate_per_week = round(mean(current_rate_per_week, na.rm = TRUE), round_digits),
sd_current_rate_per_week   = round(sd(current_rate_per_week, na.rm = TRUE), round_digits)
)
slowest <- rates_vanilla_week %>%
dplyr::filter(is.finite(current_rate_per_week)) %>%
dplyr::slice_min(current_rate_per_week, n = 1, with_ties = FALSE)
fastest <- rates_vanilla_week %>%
dplyr::filter(is.finite(current_rate_per_week)) %>%
dplyr::slice_max(current_rate_per_week, n = 1, with_ties = FALSE)
# ---- Forecast table: expected recruited participants by 31.12.2026 ----
forecast_end_date <- ideal_goal_date   # = 2026-12-31
make_forecast_table <- function(df_cum, id_cols = c("label"),
forecast_date = forecast_end_date,
cap_at_target = TRUE) {
df_cum %>%
dplyr::group_by(dplyr::across(dplyr::all_of(id_cols))) %>%
dplyr::group_modify(~{
grp <- .x %>% dplyr::arrange(date)
tgt <- dplyr::last(grp$target)
last_obs_date <- dplyr::last(grp$date)
last_obs_cum  <- dplyr::last(grp$cum_n)
fitinfo <- fit_project_lm(grp %>% dplyr::select(date, cum_n))
if (is.null(fitinfo)) {
pred_raw <- last_obs_cum
lwr_raw  <- NA_real_
upr_raw  <- NA_real_
method   <- "last_observed"
} else {
pr <- predict_lm_ci_nw(fitinfo, as.Date(forecast_date))
pred_raw <- pr$fit[1]
lwr_raw  <- pr$lwr[1]
upr_raw  <- pr$upr[1]
method   <- "linear_projection"
}
pred_use <- pred_raw
lwr_use  <- lwr_raw
upr_use  <- upr_raw
if (isTRUE(cap_at_target) && !is.na(tgt) && is.finite(tgt) && tgt > 0) {
pred_use <- pmin(pred_use, tgt)
lwr_use  <- pmin(lwr_use, tgt)
upr_use  <- pmin(upr_use, tgt)
}
tibble::tibble(
target = tgt,
last_obs_date = last_obs_date,
last_obs_cum = last_obs_cum,
forecast_date = as.Date(forecast_date),
predicted_cum_n = pred_use,
predicted_lwr = lwr_use,
predicted_upr = upr_use,
additional_expected_until_year_end = pmax(0, pred_use - last_obs_cum),
predicted_pct_of_target = ifelse(
is.na(tgt) | tgt <= 0,
NA_real_,
100 * pred_use / tgt
),
method = method
)
}) %>%
dplyr::ungroup()
}
forecast_vanilla_2026 <- make_forecast_table(
vanilla_cum,
id_cols = c("label"),
forecast_date = forecast_end_date,
cap_at_target = TRUE
) %>%
dplyr::rename(project = label) %>%
dplyr::left_join(
vanilla_cum %>% dplyr::select(label, project_num = project) %>% dplyr::distinct(),
by = c("project" = "label")
) %>%
dplyr::select(
project_num, project, target,
last_obs_date, last_obs_cum,
forecast_date, predicted_cum_n, predicted_lwr, predicted_upr,
additional_expected_until_year_end, predicted_pct_of_target, method
) %>%
dplyr::mutate(
dplyr::across(
c(target, last_obs_cum, predicted_cum_n, predicted_lwr, predicted_upr,
additional_expected_until_year_end, predicted_pct_of_target),
~ round(.x, round_digits)
)
) %>%
dplyr::arrange(project_num)
forecast_split_2026 <- make_forecast_table(
split_cum,
id_cols = c("label"),
forecast_date = forecast_end_date,
cap_at_target = TRUE
) %>%
dplyr::rename(series = label) %>%
dplyr::left_join(
split_cum %>% dplyr::select(label, project, sample) %>% dplyr::distinct(),
by = c("series" = "label")
) %>%
dplyr::select(
project, sample, series, target,
last_obs_date, last_obs_cum,
forecast_date, predicted_cum_n, predicted_lwr, predicted_upr,
additional_expected_until_year_end, predicted_pct_of_target, method
) %>%
dplyr::mutate(
dplyr::across(
c(target, last_obs_cum, predicted_cum_n, predicted_lwr, predicted_upr,
additional_expected_until_year_end, predicted_pct_of_target),
~ round(.x, round_digits)
)
) %>%
dplyr::arrange(project, sample, series)
writexl::write_xlsx(
list(
rates_vanilla_weekly = rates_vanilla_week,
rates_split_weekly   = rates_split_week,
forecast_vanilla_2026 = forecast_vanilla_2026,
forecast_split_2026   = forecast_split_2026,
summary              = rate_summary,
slowest              = slowest,
fastest              = fastest
),
path = file.path(out_dir, sprintf("%s_data_collection_rates_weekly_with_ideal.xlsx", datestamp_last))
)
message("Saved outputs in: ", normalizePath(out_dir))
#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# FOR: Illustration akkumulierte Evidenzverläufe über fünf Snippets
#
# Author: Saskia Wilken
# Created: 2026-06-19
#
# Description:
# This script creates illustrative evidence trajectories for sequential
# belief-updating scenes consisting of five snippets.
#
# Each snippet has an evidence weight:
#   +2 / +1 = evidence for Option A
#    0      = neutral or ambiguous evidence
#   -1 / -2 = evidence for Option B
#
# The evidence weights are accumulated across snippets. Thus, the plotted
# value at each snippet represents the sum of all evidence encountered up
# to that point.
#
# Output:
#   - Faceted plot showing five example evidence trajectories
#   - PNG file: evidence_trajectories_5_cumulative_stacked.png
#~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# ---- Packages ---------------------------------------------------------------
library(tidyverse)
# ---- Define evidence patterns -----------------------------------------------
# Positive values provide evidence for Option A.
# Negative values provide evidence for Option B.
# Zero represents neutral or ambiguous evidence.
evidence_patterns <- tibble(
pattern = c(
"1_stabil_klar",
"2_stabil_verrauscht",
"3_reversal",
"4_falscher_alarm",
"5_persistent_ambig"
),
values = list(
c(+1, +1, +2, +1, +2),
c(+1,  0, -1, +1, +2),
c(+2, +1, -1, -2, -2),
c(+1, +2, -2, -1, +1),
c( 0, +1, -1,  0, +1)
)
)
# ---- Reshape and accumulate evidence ----------------------------------------
evidence_patterns <- evidence_patterns %>%
unnest_longer(
values,
values_to = "snippet_weight"
) %>%
group_by(pattern) %>%
mutate(
snippet = row_number(),
cumulative_evidence = cumsum(snippet_weight)
) %>%
ungroup() %>%
mutate(
pattern = factor(
pattern,
levels = c(
"1_stabil_klar",
"2_stabil_verrauscht",
"3_reversal",
"4_falscher_alarm",
"5_persistent_ambig"
),
labels = c(
"Stabile Evidenz",
"Stabile, verrauschte Evidenz",
"Reversal / Change Point",
"Falscher Alarm",
"Persistente Ambiguität"
)
)
)
# ---- Create plot ------------------------------------------------------------
p <- ggplot(
evidence_patterns,
aes(
x = snippet,
y = cumulative_evidence,
group = pattern
)
) +
geom_hline(
yintercept = 0,
linewidth = 0.4,
linetype = "dashed"
) +
geom_line(
linewidth = 0.9
) +
geom_point(
size = 2.4
) +
facet_wrap(
~ pattern,
ncol = 1
) +
scale_x_continuous(
breaks = 1:5,
limits = c(1, 5)
) +
scale_y_continuous(
breaks = scales::breaks_width(1),
expand = expansion(mult = c(0.08, 0.08))
) +
labs(
x = "Snippet innerhalb der Szene",
y = "Akkumulierte Evidenz",
title = "Beispielhafte akkumulierte Evidenzverläufe",
subtitle = "Positive Werte sprechen für Option A, negative Werte für Option B"
) +
theme_minimal(
base_size = 12
) +
theme(
strip.text = element_text(
face = "bold",
hjust = 0
),
panel.grid.minor = element_blank(),
plot.title = element_text(
face = "bold"
),
plot.subtitle = element_text(
margin = margin(b = 8)
),
axis.title.x = element_text(
margin = margin(t = 8)
),
axis.title.y = element_text(
margin = margin(r = 8)
)
)
# ---- Display plot ------------------------------------------------------------
print(p)
# ---- Save plot ---------------------------------------------------------------
ggsave(
filename = "evidence_trajectories_5_cumulative_stacked.png",
plot = p,
width = 7,
height = 9,
dpi = 300
)
# ---- Example: evidence accumulation and participant ratings -----------------
# Brown tone used in the figure:
participant_brown <- "#877A5D"
example_accumulation <- tibble(
snippet = 1:5,
`Snippet evidence` = c(0, +1, +2, +1, +2),
`Participant-rated evidence` = c(0, +2, +4, -1, +3)
) %>%
pivot_longer(
cols = -snippet,
names_to = "evidence_type",
values_to = "evidence"
) %>%
mutate(
evidence_type = factor(
evidence_type,
levels = c(
"Snippet evidence",
"Participant-rated evidence"
)
)
)
p_example <- ggplot(
example_accumulation,
aes(
x = snippet,
y = evidence,
colour = evidence_type,
shape = evidence_type,
group = evidence_type
)
) +
geom_hline(
yintercept = 0,
linewidth = 0.4,
linetype = "dashed",
colour = "grey50"
) +
geom_line(
linewidth = 0.9
) +
geom_point(
size = 2.7,
stroke = 0.8
) +
scale_colour_manual(
values = c(
"Snippet evidence" = "black",
"Participant-rated evidence" = participant_brown
)
) +
scale_shape_manual(
values = c(
"Snippet evidence" = 16,
"Participant-rated evidence" = 17
)
) +
scale_x_continuous(
breaks = 1:5,
limits = c(1, 5)
) +
scale_y_continuous(
breaks = -1:4,
limits = c(-1.3, 4.3)
) +
labs(
x = "Snippet",
y = "Evidence",
colour = NULL,
shape = NULL
) +
theme_minimal(
base_size = 12
) +
theme(
panel.grid.minor = element_blank(),
axis.title.x = element_text(
margin = margin(t = 7)
),
axis.title.y = element_text(
margin = margin(r = 7)
),
legend.position = "top",
legend.justification = "left",
legend.text = element_text(
size = 9
),
legend.key.width = unit(
1.2,
"lines"
),
legend.spacing.x = unit(
0.15,
"cm"
),
plot.margin = margin(
6, 8, 6, 6
)
) +
guides(
colour = guide_legend(
override.aes = list(
linewidth = 0.8,
size = 2.3
)
)
)
print(p_example)
# ---- Save example plot -------------------------------------------------------
ggsave(
filename = "example_evidence_accumulation.png",
plot = p_example,
width = 5.5,
height = 3.8,
dpi = 300,
bg = "white"
)
# ---- Example: accumulated evidence and participant ratings ------------------
# Brown tone used in the figure:
participant_brown <- "#877A5D"
example_accumulation <- tibble(
snippet = 1:5,
snippet_evidence_raw = c(0, +1, +2, +1, +2),
participant_rated_raw = c(0, +2, +4, -1, +3)
) %>%
mutate(
`Snippet evidence` = cumsum(snippet_evidence_raw),
`Participant-rated evidence` = cumsum(participant_rated_raw)
) %>%
select(
snippet,
`Snippet evidence`,
`Participant-rated evidence`
) %>%
pivot_longer(
cols = -snippet,
names_to = "evidence_type",
values_to = "evidence"
) %>%
mutate(
evidence_type = factor(
evidence_type,
levels = c(
"Snippet evidence",
"Participant-rated evidence"
)
)
)
p_example <- ggplot(
example_accumulation,
aes(
x = snippet,
y = evidence,
colour = evidence_type,
shape = evidence_type,
group = evidence_type
)
) +
geom_hline(
yintercept = 0,
linewidth = 0.4,
linetype = "dashed",
colour = "grey50"
) +
geom_line(
linewidth = 0.9
) +
geom_point(
size = 2.7,
stroke = 0.8
) +
scale_colour_manual(
values = c(
"Snippet evidence" = "black",
"Participant-rated evidence" = participant_brown
)
) +
scale_shape_manual(
values = c(
"Snippet evidence" = 16,
"Participant-rated evidence" = 17
)
) +
scale_x_continuous(
breaks = 1:5,
limits = c(1, 5)
) +
scale_y_continuous(
breaks = 0:8,
limits = c(-0.3, 8.3)
) +
labs(
x = "Snippet",
y = "Accumulated evidence",
colour = NULL,
shape = NULL
) +
theme_minimal(
base_size = 12
) +
theme(
panel.grid.minor = element_blank(),
axis.title.x = element_text(
margin = margin(t = 7)
),
axis.title.y = element_text(
margin = margin(r = 7)
),
legend.position = "top",
legend.justification = "left",
legend.text = element_text(size = 9),
legend.key.width = unit(1.2, "lines"),
legend.spacing.x = unit(0.15, "cm"),
plot.margin = margin(6, 8, 6, 6)
) +
guides(
colour = guide_legend(
override.aes = list(
linewidth = 0.8,
size = 2.3
)
)
)
print(p_example)
# ---- Save example plot ------------------------------------------------------
ggsave(
filename = "example_accumulated_evidence.png",
plot = p_example,
width = 5.5,
height = 3.8,
dpi = 300,
bg = "white"
)
